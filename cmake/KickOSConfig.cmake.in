#
# find_package(KickOS) entry point: exposes the KickOS component libraries and
# the kickos_add_application() dependency-inversion helper to a consumer.

@PACKAGE_INIT@

# kickos_add_application() links via $<LINK_GROUP:RESCAN>, which needs CMake 3.24
# at the consumer; fail clearly rather than with an opaque genex error.
if(CMAKE_VERSION VERSION_LESS 3.24)
  message(FATAL_ERROR "KickOS requires CMake >= 3.24 (found ${CMAKE_VERSION})")
endif()

# The board/arch this package was built for; lets a consumer omit BOARD in
# kickos_add_application() and get the packaged target. A KickOS package is
# single-board (exactly one arch/chip/linker), so a consumer who selected a
# different board (e.g. -DKICKOS_BOARD before find_package, using their own
# toolchain) must fail clearly rather than have that name silently map to the
# packaged arch/chip. (Our shipped ARM toolchain already adopts the packaged
# board, so this only bites a genuine cross-board request.)
if(DEFINED KICKOS_BOARD AND NOT KICKOS_BOARD STREQUAL "@KICKOS_BOARD@")
  message(FATAL_ERROR "KickOS: this package was built for board '@KICKOS_BOARD@', "
    "but KICKOS_BOARD='${KICKOS_BOARD}' was requested -- a KickOS package is "
    "single-board. Use a package built for '${KICKOS_BOARD}', or unset KICKOS_BOARD.")
endif()
set(KICKOS_BOARD "@KICKOS_BOARD@")
set(KICKOS_ARCH "@KICKOS_ARCH@")
set(KICKOS_CHIP "@KICKOS_CHIP@")

# The `kickos` target pulls POSIX threads only on the host sim; a bare-metal
# package must not require Threads (there is no pthreads on an MCU).
if(KICKOS_ARCH STREQUAL "sim")
  include(CMakeFindDependencyMacro)
  find_dependency(Threads)
else()
  # The arch<->kernel<->chip archive cycle links via $<LINK_GROUP:RESCAN>. The
  # bare-metal "Generic" platform does not predefine that feature, so a consumer
  # using its own toolchain (not ours) would fail to generate. Declare it here so
  # the packaged `kickos` target links regardless of the consumer's toolchain.
  foreach(_lang C CXX ASM)
    if(NOT CMAKE_${_lang}_LINK_GROUP_USING_RESCAN_SUPPORTED)
      set(CMAKE_${_lang}_LINK_GROUP_USING_RESCAN_SUPPORTED TRUE)
      set(CMAKE_${_lang}_LINK_GROUP_USING_RESCAN "LINKER:--start-group" "LINKER:--end-group")
    endif()
  endforeach()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/kickos.cmake")
include("${CMAKE_CURRENT_LIST_DIR}/KickOSTargets.cmake")

check_required_components(KickOS)
