{
  "version": 6,
  "configurePresets": [
    {
      "name": "arm-base",
      "hidden": true,
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchain-arm-none-eabi.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "qemu",
      "displayName": "QEMU mps2-an386 (Cortex-M4F, armv7m) - runnable",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/qemu",
      "cacheVariables": { "KICKOS_BOARD": "qemu", "KICKOS_ENABLE_SELFTEST": "ON" }
    },
    {
      "name": "frdmk64f",
      "displayName": "NXP FRDM-K64F (Cortex-M4F, armv7m)",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/frdmk64f",
      "cacheVariables": { "KICKOS_BOARD": "frdmk64f" }
    },
    {
      "name": "teensy41",
      "displayName": "PJRC Teensy 4.1 (NXP i.MX RT1062, Cortex-M7)",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/teensy41",
      "cacheVariables": { "KICKOS_BOARD": "teensy41" }
    },
    {
      "name": "f411disco",
      "displayName": "STM32F411 Discovery (Cortex-M4F, armv7m)",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/f411disco",
      "cacheVariables": { "KICKOS_BOARD": "f411disco" }
    },
    {
      "name": "blackpill",
      "displayName": "WeAct STM32F411CEU6 Black Pill (Cortex-M4F, armv7m)",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/blackpill",
      "cacheVariables": { "KICKOS_BOARD": "blackpill" }
    },
    {
      "name": "bluepill-c8",
      "displayName": "STM32F103C8 Blue Pill, genuine 20 KiB (Cortex-M3)",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/bluepill-c8",
      "cacheVariables": { "KICKOS_BOARD": "bluepill-c8" }
    },
    {
      "name": "microbit",
      "displayName": "BBC micro:bit v1 (nRF51, Cortex-M0, armv6m) - runnable",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/microbit",
      "cacheVariables": { "KICKOS_BOARD": "microbit", "KICKOS_ENABLE_SELFTEST": "ON" }
    },
    {
      "name": "picopi",
      "displayName": "Raspberry Pi Pico (RP2040, Cortex-M0+, armv6m)",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/picopi",
      "cacheVariables": { "KICKOS_BOARD": "picopi" }
    },
    {
      "name": "pizero2350",
      "displayName": "Waveshare RP2350 Pi-Zero (Cortex-M33, armv7m)",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/pizero2350",
      "cacheVariables": { "KICKOS_BOARD": "pizero2350" }
    },
    {
      "name": "f302nucleo",
      "displayName": "ST Nucleo-F302R8 (Cortex-M4F, armv7m)",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/f302nucleo",
      "cacheVariables": { "KICKOS_BOARD": "f302nucleo" }
    },
    {
      "name": "due",
      "displayName": "Arduino Due (AT91SAM3X8E, Cortex-M3) [EXPERIMENTAL: clock/console]",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/due",
      "cacheVariables": { "KICKOS_BOARD": "due" }
    },
    {
      "name": "xmc4800-relax",
      "displayName": "Infineon XMC4800 Relax Kit (Cortex-M4F, armv7m)",
      "inherits": "arm-base",
      "binaryDir": "${sourceDir}/build/xmc4800-relax",
      "cacheVariables": { "KICKOS_BOARD": "xmc4800-relax" }
    },
    {
      "name": "qemu-telem",
      "displayName": "QEMU mps2-an386 + telemetry - QEMU structural gate (PendSV asm)",
      "inherits": "qemu",
      "binaryDir": "${sourceDir}/build/qemu-telem",
      "cacheVariables": {
        "KICKOS_TELEMETRY": "rtt",
        "KICKOS_CONSOLE": "both"
      }
    },
    { "name": "frdmk64f-st", "displayName": "FRDM-K64F + selftest (full IRQ suite)", "inherits": "frdmk64f", "binaryDir": "${sourceDir}/build/frdmk64f-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } },
    { "name": "teensy41-st", "displayName": "Teensy 4.1 + selftest (full IRQ suite)", "inherits": "teensy41", "binaryDir": "${sourceDir}/build/teensy41-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } },
    { "name": "xmc4800-relax-st", "displayName": "XMC4800 Relax + selftest (full IRQ suite)", "inherits": "xmc4800-relax", "binaryDir": "${sourceDir}/build/xmc4800-relax-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } },
    { "name": "f411disco-st", "displayName": "STM32F411 Disco + selftest", "inherits": "f411disco", "binaryDir": "${sourceDir}/build/f411disco-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } },
    { "name": "blackpill-st", "displayName": "STM32F411 Black Pill + selftest", "inherits": "blackpill", "binaryDir": "${sourceDir}/build/blackpill-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } },
    { "name": "bluepill-c8-st", "displayName": "STM32F103C8 Blue Pill + selftest", "inherits": "bluepill-c8", "binaryDir": "${sourceDir}/build/bluepill-c8-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } },
    { "name": "picopi-st", "displayName": "RP2040 Pico + selftest", "inherits": "picopi", "binaryDir": "${sourceDir}/build/picopi-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } },
    { "name": "pizero2350-st", "displayName": "RP2350 Pi-Zero + selftest", "inherits": "pizero2350", "binaryDir": "${sourceDir}/build/pizero2350-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } },
    { "name": "f302nucleo-st", "displayName": "Nucleo-F302R8 + selftest", "inherits": "f302nucleo", "binaryDir": "${sourceDir}/build/f302nucleo-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } },
    { "name": "due-st", "displayName": "Arduino Due + selftest", "inherits": "due", "binaryDir": "${sourceDir}/build/due-st", "cacheVariables": { "KICKOS_ENABLE_SELFTEST": "ON" } }
  ],
  "buildPresets": [
    { "name": "qemu",      "configurePreset": "qemu" },
    { "name": "qemu-telem", "configurePreset": "qemu-telem" },
    { "name": "frdmk64f",  "configurePreset": "frdmk64f" },
    { "name": "teensy41",  "configurePreset": "teensy41" },
    { "name": "f411disco", "configurePreset": "f411disco" },
    { "name": "blackpill",  "configurePreset": "blackpill" },
    { "name": "bluepill-c8", "configurePreset": "bluepill-c8" },
    { "name": "microbit",  "configurePreset": "microbit" },
    { "name": "picopi",    "configurePreset": "picopi" },
    { "name": "pizero2350", "configurePreset": "pizero2350" },
    { "name": "f302nucleo","configurePreset": "f302nucleo" },
    { "name": "due",       "configurePreset": "due" },
    { "name": "xmc4800-relax", "configurePreset": "xmc4800-relax" },
    { "name": "frdmk64f-st", "configurePreset": "frdmk64f-st" },
    { "name": "teensy41-st", "configurePreset": "teensy41-st" },
    { "name": "xmc4800-relax-st", "configurePreset": "xmc4800-relax-st" },
    { "name": "f411disco-st", "configurePreset": "f411disco-st" },
    { "name": "blackpill-st", "configurePreset": "blackpill-st" },
    { "name": "bluepill-c8-st", "configurePreset": "bluepill-c8-st" },
    { "name": "picopi-st", "configurePreset": "picopi-st" },
    { "name": "pizero2350-st", "configurePreset": "pizero2350-st" },
    { "name": "f302nucleo-st", "configurePreset": "f302nucleo-st" },
    { "name": "due-st", "configurePreset": "due-st" }
  ],
  "testPresets": [
    { "name": "qemu",       "configurePreset": "qemu",       "output": { "outputOnFailure": true } },
    { "name": "qemu-telem", "configurePreset": "qemu-telem", "output": { "outputOnFailure": true } },
    { "name": "microbit",   "configurePreset": "microbit",   "output": { "outputOnFailure": true } }
  ]
}
