#
# KickOS house style, matched to the sibling projects ../KickCAT and ../kickmsg
# (whose canonical style is their uncrustify.cfg): Allman braces, 4-space
# indent, indented namespaces, indented case labels, left-aligned pointers,
# leading-comma constructor initializers, and preserved one-liners. ColumnLimit
# 0 keeps hand-wrapped lines (uncrustify does not hard-wrap either).
---
Language: Cpp
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 0

BreakBeforeBraces: Allman
NamespaceIndentation: All
IndentCaseLabels: true
AccessModifierOffset: -4
IndentExternBlock: NoIndent

PointerAlignment: Left
DerivePointerAlignment: false
SpaceAfterTemplateKeyword: false

BreakConstructorInitializers: BeforeComma

# Qualifier convention: east-const ("char const*", like KickCAT/kickmsg) but
# WEST volatile ("volatile T x" -- reads as "the whole object is volatile").
# NOT auto-enforced: clang-format's QualifierAlignment is experimental and can
# misplace qualifiers in macros/templates. Left at the default (Leave) so it
# preserves existing qualifier order without rewriting it. Write them by hand.

# Preserve one-liners (uncrustify: nl_*_leave_one_liners = true; braces not
# forced: mod_full_brace_* = ignore).
AllowShortFunctionsOnASingleLine: All
AllowShortBlocksOnASingleLine: Always
AllowShortIfStatementsOnASingleLine: AllIfsAndElse
AllowShortLoopsOnASingleLine: true

SortIncludes: false
InsertBraces: false
FixNamespaceComments: false
